# PostgreSQL — asyncpg driver (used by the app at runtime)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/p2p_journal

# PostgreSQL — psycopg2 driver (used by Alembic migrations only)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/p2p_journal

# JWT — generate a strong random value for production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Base chain RPC (defaults are fine for mainnet)
BASE_RPC_URL=https://mainnet.base.org
DIAMOND_ADDRESS=0x4cad6eC90e65baBec9335cAd728DDC610c316368

# CORS — comma-separated list of allowed frontend origins
# pydantic-settings parses this as a JSON array
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Gotify push notifications — see GOTIFY_SETUP.md for setup instructions
GOTIFY_URL=http://localhost:9090
GOTIFY_APP_TOKEN=your-gotify-app-token
